# ── Supabase ────────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER SIDE ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Project Settings → Database → Connection string (URI). Used by migrations,
# seed and RLS tests. Direct connection (port 5432) preferred.
SUPABASE_DB_URL=

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Resend ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="AJH Website Management <hello@ajhwebsitemanagement.com>"

# ── Stripe (Phase 5 — leave blank until then) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Cron (Phase 4+) — shared secret checked by Vercel Cron routes ───────────
CRON_SECRET=

# ── Seed & RLS tests only (never used in production) ────────────────────────
SEED_USER_PASSWORD=Change-me-please-1!
